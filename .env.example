# Copy this file to `.env` and fill in your own key.
# Get one at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override the default model. See https://openrouter.ai/models
# Examples:
#   deepseek/deepseek-v4-flash
#   anthropic/claude-sonnet-4.5
#   anthropic/claude-opus-4.5
#   deepseek/deepseek-chat
#   openai/gpt-4o
#   google/gemini-2.5-flash
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Optional: abort slow upstream model requests instead of leaving the UI waiting.
CHAT_UPSTREAM_TIMEOUT_MS=20000

# Optional: site URL sent to OpenRouter for analytics. Defaults to localhost in dev.
# OPENROUTER_SITE_URL=https://your-deployed-site.com

# Optional: chat server port for local dev.
# Railway provides PORT automatically in production, so do not set PORT there.
PORT=8787

# Optional: use an absolute chat endpoint when the frontend is served away from Vite.
# In local dev, leave this unset so Vite proxies /api/chat to the server.
# VITE_CHAT_API_URL=http://localhost:8787/api/chat
